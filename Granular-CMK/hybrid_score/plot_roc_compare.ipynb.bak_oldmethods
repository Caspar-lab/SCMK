    "# 逐数据集计算 (数据集 × 方法) 的 ROC\n",
    "#   scatter      : seed=2 半监督协议，在【测试集】(held-out 50% 正常 + 全部异常) 上评测\n",
    "#   9 对比算法   : 与之前相同，在【全量数据】(所有样本) 上评测 —— AUC 与汇总表一致\n",
    "RESULTS = {}   # stem -> {method: (fpr, tpr, auc)}\n",
    "for stem in DATASETS:\n",
    "    _, y = load_xy(stem)\n",
    "    train_idx, test_idx, y_te = get_split(stem)\n",
    "    RESULTS[stem] = {}\n",
    "    for m in METHODS:\n",
    "        try:\n",
    "            if m == 'scatter':\n",
    "                sc, y_eval = get_scatter_scores_test(stem, train_idx, test_idx), y_te\n",
    "            else:\n",
    "                sc, y_eval = get_alg_scores(m, stem, y), y      # 9 对比算法（含 DFNO）全量评测\n",
    "            if sc is None:\n",
    "                continue\n",
    "            fpr, tpr, _ = roc_curve(y_eval, sc)\n",
    "            RESULTS[stem][m] = (fpr, tpr, roc_auc_score(y_eval, sc))\n",
    "        except Exception as e:\n",
    "            print('ERR', m, stem, ':', e)\n",
    "    aucs = '  '.join(f'{m}={RESULTS[stem][m][2]:.3f}' for m in METHODS if m in RESULTS[stem])\n",
    "    print(f'{stem:<36} {aucs}')\n",
    "print('done')"
   ]
