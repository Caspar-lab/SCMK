    "def load_xy(stem):\n",
    "    d = sio.loadmat(os.path.join(DATA_ROOT, stem + '.mat'))\n",
    "    t = d['trandata'].astype(float)\n",
    "    y = (t[:, -1] != 0).astype(int)\n",
    "    return t, y\n",
    "\n",
    "def get_split(stem):\n",
    "    \"\"\"半监督 50/50 划分：train=50% 正常；test=其余 50% 正常 + 全部异常。\"\"\"\n",
    "    _, y = load_xy(stem)\n",
    "    train_idx, test_idx = split_indices(y, SPLIT_SEED)   # frac=TRAIN_FRAC(=0.5)\n",
    "    return train_idx, test_idx, (y[test_idx] != 0).astype(int)\n",
    "\n",
    "def get_scatter_scores_test(stem, train_idx, test_idx):\n",
    "    \"\"\"\n",
    "    seed=2 半监督协议下 scatter(max_ensemble) 在【测试集】上的异常分数。\n",
    "    仅用训练集正常样本估带宽 + 训练 CMK + 拟合 OC-SVM，只对测试集打分；\n",
    "    与 run_hybrid_score_semi.ensemble_auc_split 完全同源，AUC 复现 scatter_semi_seed2。\n",
    "    \"\"\"\n",
    "    X, y, _ = load_data(os.path.join(DATA_ROOT, stem + '.mat'))\n",
    "    dim, lam = BEST_CFG[stem]\n",
    "    kernels  = gauss_med_kernels(X[train_idx])                 # 仅训练集估带宽\n",
    "    cfg      = {**BASE_CFG, 'lambda_scatter': lam}\n",
    "    model    = train_cmk_scatter(X[train_idx], np.zeros(len(train_idx), int),\n",
    "                                 kernels, dim, device, cfg)\n",
    "    H_norm_per, H_norms = extract_components(model, X, device) # 全量一次前向\n",
    "    H_dir  = np.concatenate(H_norm_per, axis=1)\n",
    "    y_test = (y[test_idx] != 0).astype(int)\n",
    "    _, _, s_dir = _best_ocsvm_scores(H_dir[test_idx],   y_test,\n",
    "                                     H_dir[train_idx],   'linear', NU_CANDIDATES)\n",
    "    _, _, s_nrm = _best_ocsvm_scores(H_norms[test_idx], y_test,\n",
    "                                     H_norms[train_idx], 'rbf',    NU_CANDIDATES)\n",
    "    if s_dir is None:\n",
    "        return _minmax(s_nrm)\n",
    "    if s_nrm is None:\n",
    "        return _minmax(s_dir)\n",
    "    return np.maximum(_minmax(s_dir), _minmax(s_nrm))\n",
    "\n",
    "# KFGOD 特殊路径；其余对比算法（含 DFNO）在 Experimental_results\n",
    "KFGOD_DIR = 'C:/OD/Shihao/KFGOD-main/results'\n",
    "\n",
    "def _find_mat(alg, stem):\n",
    "    folder = os.path.join(ER, f'{alg}_results', stem)\n",
    "    if not os.path.isdir(folder):\n",
    "        return None\n",
    "    exact = os.path.join(folder, f'{stem}_{alg}.mat')\n",
    "    if os.path.exists(exact):\n",
    "        return exact\n",
    "    c = [f for f in os.listdir(folder) if f.endswith(f'{stem}_{alg}.mat')]\n",
    "    if c:\n",
    "        return os.path.join(folder, sorted(c, key=len)[0])\n",
    "    c = [f for f in os.listdir(folder)\n",
    "         if f.endswith(f'_{alg}.mat') and '_k-' not in f and '_run' not in f]\n",
    "    return os.path.join(folder, sorted(c, key=len)[0]) if c else None\n",
    "\n",
    "def get_alg_scores(alg, stem, y):\n",
    "    \"\"\"对比算法【全量】异常分数（无监督，对所有样本打分），长度与 y 对齐。\"\"\"\n",
    "    if alg == 'KFGOD':\n",
    "        p = os.path.join(KFGOD_DIR, stem, f'{stem}_KFGOD.mat')\n",
    "        if not os.path.exists(p):\n",
    "            return None\n",
    "        s = np.asarray(sio.loadmat(p)['opt_out_scores'])[:, 0].ravel()\n",
    "        return s if len(s) == len(y) else None\n",
    "    p = _find_mat(alg, stem)\n",
    "    if p is None:\n",
    "        return None\n",
    "    s = np.asarray(sio.loadmat(p)['opt_out_scores'])[:, 0].ravel()\n",
    "    return s if len(s) == len(y) else None"
   ]
