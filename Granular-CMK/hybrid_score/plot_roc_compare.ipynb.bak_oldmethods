    "import os, sys\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import scipy.io as sio\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import roc_curve, roc_auc_score\n",
    "import torch\n",
    "\n",
    "NB_DIR = 'C:/OD/Shihao/5/Granular-CMK/hybrid_score'\n",
    "if NB_DIR not in sys.path:\n",
    "    sys.path.insert(0, NB_DIR)\n",
    "# 半监督 50/50 划分所需的训练 / 评分原语（与 run_hybrid_score_semi.py 完全一致）\n",
    "from run_hybrid_score import gauss_med_kernels, extract_components, _best_ocsvm_scores, _minmax\n",
    "from run_hybrid_score_semi import split_indices, TRAIN_FRAC\n",
    "from CMK_OCSVM import NU_CANDIDATES, TRAIN_CFG as BASE_CFG, load_data\n",
    "from CMK_OCSVM_scatter import train_cmk_scatter\n",
    "\n",
    "DATA_ROOT  = 'C:/OD/Shihao/datasets'               # 全量数据集 .mat（标签 trandata）\n",
    "ER         = 'C:/OD/Shihao/Experimental_results'    # 对比算法分数结果\n",
    "SEMI_DIR   = 'C:/OD/Shihao/5/result/hybrid_score_semi'\n",
    "RESULT_DIR = SEMI_DIR                               # ROC 图输出目录\n",
    "SEL_CSV    = os.path.join(SEMI_DIR, 'selection_scatter_semi_seed2.csv')\n",
    "ALL_CSV    = os.path.join(SEMI_DIR, 'hybrid_semi_all.csv')\n",
    "\n",
    "SPLIT_SEED = 2     # 半监督 50/50 划分种子（与 selection_scatter_semi_seed2 一致）\n",
    "\n",
    "# plot_SMS 风格\n",
    "plt.rcParams['font.size'] = 13\n",
