    "# 9 对比算法（绘图顺序，年份用于标注）+ scatter\n",
    "ALG_YEAR = {'KFGOD': 2024, 'DFNO': 2024, 'GBRAD': 2025, 'Disent_AD': 2025,\n",
    "            'MFIOD': 2024, 'ILGNI': 2023, 'WFRDA': 2023, 'DIF': 2022, 'ECOD': 2022}\n",
    "METHODS = list(ALG_YEAR.keys()) + ['scatter']\n",
    "\n",
    "# 数据集清单来自 seed=2 的 20 数据集挑选结果\n",
    "sel      = pd.read_csv(SEL_CSV)\n",
    "DATASETS = list(sel['dataset'])\n",
    "\n",
    "# 每数据集在 split_seed=2 下网格最优 (dim, lambda) —— 复现 scatter_semi_seed2 的 AUC\n",
    "_all = pd.read_csv(ALL_CSV)\n",
    "_s2  = _all[_all['split_seed'] == SPLIT_SEED]\n",
    "BEST_CFG = {}\n",
    "for st in DATASETS:\n",
    "    sub = _s2[_s2['dataset'] == st]\n",
    "    br  = sub.loc[sub['auc'].idxmax()]\n",
    "    BEST_CFG[st] = (int(br['latent_dim']), float(br['lambda_scatter']))\n",
    "print(f'{len(DATASETS)} datasets, {len(ALG_YEAR)} comparison algs | '\n",
    "      f'semi {int(TRAIN_FRAC*100)}/{100-int(TRAIN_FRAC*100)} split, seed={SPLIT_SEED}')"
   ]
