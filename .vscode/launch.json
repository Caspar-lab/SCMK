{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "justMyCode": true,
            "env": {
                "CONDA_DEFAULT_ENV": "torch311"
            }
        },
        {
            "name": "CMK_OCSVM (cardio)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\Granular-CMK\\CMK_OCSVM.py",
            "args": ["${workspaceFolder}\\dataset\\numerical\\cardio.mat"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}\\Granular-CMK",
            "justMyCode": false
        },
        {
            "name": "CMK-RW (cardio)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\Granular-CMK\\CMK-RW\\cmk_rw.py",
            "args": ["${workspaceFolder}\\dataset\\numerical\\cardio.mat"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}\\Granular-CMK\\CMK-RW",
            "justMyCode": false
        }
    ]
}
